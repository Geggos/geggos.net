---
import { Image } from "astro:assets";
import geggonet from "../assets/geggonet.png";

const { pathname } = Astro.url;
const isActive = (href: string) => {
    if (href === "/") {
        return pathname === "/";
    }
    return pathname.startsWith(href);
};

const linkClass =
    "font-medium text-gray-600 hover:text-gray-900 transition-colors";
const activeClass =
    "font-bold text-black underline decoration-2 underline-offset-4";

const links = [
    { href: "/", label: "Home" },
    { href: "/projects", label: "Projects" },
    { href: "/blog", label: "Blog" },
    { href: "/gallery", label: "Gallery" },
    { href: "/ask", label: "Ask" },
    { href: "/guestbook", label: "Guestbook" },
    { href: "/archive", label: "Archive" },
];
---

<header class="w-full bg-white shadow-sm z-50 relative">
    <nav
        class="flex flex-col md:flex-row items-center justify-between px-4 py-2 md:px-8 max-w-7xl mx-auto gap-4"
    >
        <!-- Logo -->
        <a
            href="/"
            class="shrink-0 transition-transform duration-300 hover:-rotate-3 active:scale-90"
        >
            <Image
                src={geggonet}
                alt="Geggos.net logo"
                class="h-16 w-auto object-contain"
                loading="eager"
                transition:name="header-logo"
            />
        </a>

        <!-- Links -->
        <div class="flex flex-wrap justify-center items-center gap-x-6 gap-y-2">
            {
                links.map((link) => (
                    <a
                        href={link.href}
                        class:list={[
                            linkClass,
                            isActive(link.href) && activeClass,
                        ]}
                    >
                        {link.label}
                    </a>
                ))
            }
        </div>
    </nav>
</header>
