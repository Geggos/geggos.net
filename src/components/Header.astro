---
import { Image } from "astro:assets";
import geggonet from "../assets/geggonet.png";

const { pathname } = Astro.url;
const isActive = (href: string) => {
    if (href === "/") {
        return pathname === "/";
    }
    return pathname.startsWith(href);
};

const linkClass =
    "text-xl md:text-lg link-a text-gray-600 hover:text-gray-900 transition-colors";
const activeClass =
    "text-xl md:text-lg link-active";
const click_anim =
    "transition-transform duration-100 hover:-rotate-3 active:scale-90 select-none"


const links = [
    { href: "/", label: "Home" },
    { href: "/projects", label: "Projects" },
    { href: "/blog", label: "Blog" },
    { href: "/gallery", label: "Gallery" },
    { href: "/ask", label: "Ask" },
    { href: "/guestbook", label: "Guestbook" },
    { href: "/archive", label: "Archive" },
];
---

<header class="w-full shadow-sm z-50 relative">
    <nav class="flex flex-col md:flex-row items-center justify-between px-4 py-2 md:px-8 max-w-7xl mx-auto gap-4">
        <!-- Logo -->
        <a
            href="/"
            class={click_anim}
        >
            <Image
                src={geggonet}
                alt="Geggos.net logo"
                class="h-16 w-auto object-contain pointer-events-none select-none"
                loading="eager"
                transition:name="header-logo"
            />
        </a>

        <!-- Links -->
        <div class="flex flex-wrap justify-center items-center gap-x-6 gap-y-4 font-cute">
            {
                links.map((link) => (
                    <a
                        href={link.href}
                        class:list={[
                            linkClass,
                            isActive(link.href) && activeClass,
                        ]}
                    >
                        {link.label}
                    </a>
                ))
            }
        </div>
    </nav>
</header>

<style>
    header {
        background-color: var(--bg-accent-transparent);
        border-bottom: 2px dashed var(--bg-accent);
    }
    @media (max-width: 768px) {
        header {
            padding: 0em 1em 1em 1em;
        }
    }
    .link-a {
        color: var(--accent-secondary-inactive);
        text-align: center;
        font-weight: bold;
        /* EVIL FUCKED UP SHADOW PLUS OUTLINE HACK DONT ASK */
        text-shadow:
            -1px -1px 0 white,
            1px -1px 0 white,
            -1px 1px 0 white,
            1px 1px 0 white,
            -1px 0 0 white,
            1px 0 0 white,
            0 -1px 0 white,
            0 1px 0 white,
            -1px 3px 0px rgba(0, 0, 0, 0.35);
        contain: layout;
    }
    .link-a:hover{
        color: var(--accent-secondary-inactive-hover);
        transform: rotate(3deg);
    }
    .link-active {
        color: var(--accent-secondary);
        rotate: 3deg;
        contain: layout;
    }
    .link-active:hover {
        transform: none;
        color: var(--accent-secondary);
    }
</style>