---
import Main from "../layouts/Main.astro";
import { Image } from "astro:assets";
import geggobanner from "../assets/geggobanner.png";
import buh from "../assets/ezgif.com-optiwebp.webp";

---
<Main>
    <div class="w-screen relative left-1/2 -translate-x-1/2">
        <Image
            src={geggobanner}
            alt="a banner of Geggos and his friends"
            class="index-banner shadow-md"
        />
    </div>
    <div class="my-16 text-center flex flex-col">
        <h1>Welcome to Geggos.net!</h1>
        <hr />
        <div class="flex flex-col">
            <span>placeholder placeholder buh buh buh lorem ipsum lorem ipsum buh i really like burgers placeholder placeholder buh buh buh lorem ipsum lorem ipsum buh i really like burgers</span>
            <span>placeholder placeholder buh buh buh lorem ipsum lorem ipsum buh i really like burgers</span>
            <span>ideally socials etc would go here</span>
        </div>
    </div>
</Main>

<style>
    .index-banner {
        width: 100%;
        max-height: 600px;
        object-fit: cover;
        object-position: center -32px;
    }
    
    h1:hover {
        transform: rotate(-0.5deg) !important;
    }
    h1:active {
        transform: scale(0.95) !important;
    }
</style>
