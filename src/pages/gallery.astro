---
import Main from "../layouts/Main.astro";
import { Image } from "astro:assets";
import placeholder from "../assets/blog-placeholder-3.jpg"
import galleryComics from '../assets/gallery-banners/banner_3.png'
import galleryMisc from '../assets/gallery-banners/geggobanner.png'
import galleryChristmas from '../assets/gallery-banners/hohoohohoh.png'
---

<Main>
    <div class="my-16 text-center flex flex-col">
        <h1>Gallery</h1>
        <hr />
        <span class="my-16 font-cute text-xl">placeholder placeholder buh buh buh lorem ipsum lorem ipsum buh i really like burgers</span>
        <div class="gallery-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-2 self-center">
            <a class="gallery-link relative">
                <div class="gallery-section shadow-md">
                    <Image src={galleryComics} alt="placeholder" class="object-right" />
                    <p class="font-cute font-semibold text-2xl color-accent">Comics</p>
                </div>
            </a>
            <a class="gallery-link relative">
                <div class="gallery-section shadow-md">
                    <Image src={galleryMisc} alt="placeholder" class="object-top" />
                    <p class="font-cute font-semibold text-2xl color-accent">Misc</p>
                </div>
            </a>
            <a class="gallery-link relative">
                <div class="gallery-section shadow-md">
                    <Image src={galleryChristmas} alt="placeholder" class="object-right" />
                    <p class="font-cute font-semibold text-2xl color-accent">Christmas</p>
                </div>
            </a>
        </div>
    </div>
</Main>

<style>
    .gallery-section {
        width: 100%;
        padding: 0.5em;
        border: 4px solid var(--bg-accent-transparent);
        border-radius: 32px;
        user-select: none;
        will-change: transform;
        position: relative;
        display: flex;
        flex-direction: column;
        gap: 1em;
    }

    .gallery-link {
        width: min(100%, 380px);
        justify-self: center;
    }

    /*
        This animation pushes the element slightly upwards
        without adjusting the element hitbox, which prevents jitter
        It also accounts for the squish animation on click
    */
    .gallery-link > .gallery-section {
        transition: transform 80ms ease-out;
    }
    .gallery-link:hover > .gallery-section {
        transform: translateY(-4px);
    }
    .gallery-link:active > .gallery-section {
        transform: scale(0.98) translateY(-4px);
    }

    .gallery-section > img {
        width: 100%;
        aspect-ratio: 2 / 1;
        object-fit: cover;
        border-radius: calc(32px - 0.5em);
        pointer-events: none;
    }
    .gallery-section > p {
        align-self: center;
        padding-bottom: 0.5em;
    }
    @media (min-width: 768px) and (max-width: 1023px) {
        .gallery-grid > :last-child:nth-child(odd) {
            grid-column: 1 / -1;
            justify-self: center;
        }
    }

    @media (max-width: 768px) {
        .gallery-section > img {
            aspect-ratio: 3 / 2;
        }
    }

    /* i deserve to be taken out back and shot */
    @media (min-width: 1024px) {
        .gallery-grid {
            grid-template-columns: repeat(6, minmax(0, 1fr));
        }
        .gallery-grid > * {
            grid-column: span 2;
        }
        .gallery-grid > :last-child:nth-child(3n + 1) {
            grid-column: 3 / span 2;
        }
        .gallery-grid > :nth-last-child(2):nth-child(3n + 1) {
            grid-column: 2 / span 2;
        }
        .gallery-grid > :last-child:nth-child(3n + 2) {
            grid-column: 4 / span 2;
        }
    }
</style>
